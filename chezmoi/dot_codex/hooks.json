{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.agents/bin/ensure-agent-stack.sh session-start text",
            "timeout": 10,
            "statusMessage": "Loading shared agent stack"
          }
        ]
      }
    ]
  }
}
