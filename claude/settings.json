{
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/scripts/file-suggestion.sh"
  },
  "permissions": {
    "allow": [
      "Bash(claude:*)",
      "Bash(ls:*)",
      "Bash(openssl rand:*)",
      "Bash(agent-browser:*)",
      "Bash(npx playwright:*)",
      "Bash(grep:*)",
      "Bash(pnpm tsc:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(git reset:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Task(Explore)"
    ]
  },
  "model": "claude-opus-4-6",
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/home/guisaliba/.bun/bin/bun\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "high",
  "defaultMode": "auto",
  "skipAutoPermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/node_modules/cavemem/dist/index.js hook run session-start --ide claude-code"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/node_modules/cavemem/dist/index.js hook run user-prompt-submit --ide claude-code"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/node_modules/cavemem/dist/index.js hook run post-tool-use --ide claude-code"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/node_modules/cavemem/dist/index.js hook run stop --ide claude-code"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/node_modules/cavemem/dist/index.js hook run session-end --ide claude-code"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cavemem": {
      "command": "/usr/local/lib/node_modules/cavemem/dist/index.js",
      "args": [
        "mcp"
      ]
    }
  }
}
