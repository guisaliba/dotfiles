{
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/scripts/file-suggestion.sh"
  },
  "permissions": {
    "allow": [
      "Bash(claude:*)",
      "Bash(ls:*)",
      "Bash(openssl rand:*)",
      "Bash(agent-browser:*)",
      "Bash(npx playwright:*)",
      "Bash(grep:*)",
      "Bash(pnpm tsc:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(git reset:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Task(Explore)"
    ],
    "defaultMode": "default"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/home/guisaliba/.bun/bin/bun\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)src/index.ts\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
