{
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/scripts/file-suggestion.sh"
  },
  "permissions": {
    "deny": [
      "Task(Explore)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"$(command -v node)\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  }
}
